}

.summary-row.total-row {
  border-top: 2px solid var(--border-default);
  padding-top: 10px;
  margin-top: 4px;
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--text-primary);
}

.tip-section {
  background: var(--bg-surface);
  border-radius: var(--radius-klg);
  padding: 20px;
  border: 1px solid var(--border-subtle);
}

.tip-section h3 {
  margin-bottom: 14px;
  font-weight: 600;
}

.tip-btns {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.tip-btn {
  flex: 1;
  min-width: 90px;
  padding: 14px 10px;
  border-radius: var(--radius-kmd);
  border: 1px solid var(--border-default);
  background: var(--bg-glass);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  transition: all .2s var(--ease-out);
}

.tip-btn:hover {
  border-color: var(--clr-primary);
  background: var(--bg-glass-hover);
}

.tip-btn.active {
  background: var(--clr-primary);
  border-color: var(--clr-primary-light);
  color: #fff;
  box-shadow: var(--shadow-glow);
}

.tip-pct {
  font-weight: 700;
  font-size: .95rem;
}

.tip-amt {
  font-size: .75rem;
  color: var(--text-muted);
}

.tip-btn.active .tip-amt {
  color: rgba(255, 255, 255, .7);
}

.tip-custom {
  display: flex;
  gap: 8px;
  flex-basis: 100%;
  margin-top: 6px;
}

.tip-custom input {
  flex: 1;
  padding: 10px 14px;
  border-radius: var(--radius-kmd);
  border: 1px solid var(--border-default);
  background: var(--bg-glass);
  color: var(--text-primary);
  font-size: .875rem;
  font-family: inherit;
}

.tip-custom input:focus {
  outline: none;
  border-color: var(--clr-primary);
}

.tip-apply {
  padding: 10px 20px;
  border-radius: var(--radius-kmd);
  border: 1px solid var(--clr-primary);
  background: transparent;
  color: var(--clr-primary-light);
  font-weight: 600;
  font-size: .85rem;
  transition: all .2s;
}

.tip-apply:hover {
  background: var(--clr-primary);
  color: #fff;
}

.customer-section {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.customer-section label {
  font-size: .85rem;
  color: var(--text-secondary);
  font-weight: 500;
}

.customer-section input {
  padding: 12px 16px;
  border-radius: var(--radius-kmd);
  border: 1px solid var(--border-default);
  background: var(--bg-glass);
  color: var(--text-primary);
  font-size: .95rem;
  font-family: inherit;
}

.customer-section input:focus {
  outline: none;
  border-color: var(--clr-primary);
}

.pay-btn {
  padding: 16px;
  border-radius: var(--radius-kmd);
  border: none;
  background: var(--clr-pink);
  /* Electric Pink */
  color: #fff;
  font-weight: 800;
  font-size: 1.15rem;
  letter-spacing: .02em;
  transition: all .25s var(--ease-out);
  box-shadow: 0 4px 14px rgba(255, 30, 144, 0.35);
}

.pay-btn:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(255, 30, 144, 0.5);
  background: #ff339b;
  /* Slightly lighter pink on hover */
}

.pay-btn:disabled {
  opacity: .5;
  cursor: not-allowed;
}

/*Order Sidebar*/
.order-sidebar {
  width: 260px;
  min-width: 220px;
  display: flex;
  flex-direction: column;
  padding: 16px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-klg);
  grid-column: 2;
  grid-row: 1;
  overflow: hidden;
}

.sidebar-title {
  margin-bottom: 16px;
  font-size: 1.1rem;
  color: var(--text-primary);
}

.toast {
  padding: 10px 20px;
  border-radius: var(--radius-kmd);
  font-size: .85rem;
  font-weight: 600;
  animation: slideIn .3s var(--ease-out);
}

.toast-success {
  background: rgba(136, 176, 75, 0.15);
  /* Matcha green */
  color: var(--clr-success);
  border: 1px solid rgba(136, 176, 75, 0.3);
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(-8px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.order-items-list {
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding-right: 8px;
}

.empty-order {
  color: var(--text-muted);
  text-align: center;
  padding: 40px 0;
  font-size: .875rem;
}

.order-row {
  padding: 10px 0;
  border-bottom: 1px solid var(--border-subtle);
}

.order-row-top {
  display: flex;
  align-items: center;
  gap: 8px;
}

.order-icon-mini {
  width: 36px;
  height: 44px;
  flex-shrink: 0;
}

.order-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 1px;
  min-width: 0;
}

.order-item-name {
  font-weight: 500;
  font-size: .85rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.order-item-price {
  font-weight: 600;
  color: var(--clr-accent);
  font-size: .8rem;
}

.remove-btn {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  border: none;
  background: rgba(239, 68, 68, .15);
  color: var(--clr-danger);
  font-size: .7rem;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all .2s;
}

.remove-btn:hover {
  background: var(--clr-danger);
  color: #fff;
}

.order-addons {
  display: flex;
  flex-direction: column;
  gap: 2px;
  margin-top: 4px;
}

.order-addon-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 4px 6px;
  border-radius: 6px;
  background: var(--bg-glass);
  font-size: 0.75rem;
  color: var(--text-secondary);
}

.addon-remove-btn {
  background: none;
  border: none;
  color: var(--text-muted);
  font-size: 0.65rem;
  cursor: pointer;
  padding: 2px 4px;
  border-radius: 4px;
  transition: all 0.15s;
  line-height: 1;
}

.addon-remove-btn:hover {
  background: rgba(239, 68, 68, .12);
  color: var(--clr-danger);
}

/* Mini pearl icon in cart addon rows */
.addon-row-icon-wrap {
  display: flex;
  align-items: center;
  gap: 4px;
}

.addon-row-pearl-svg {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
}

.order-total-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 0 12px;
  border-top: 2px solid var(--border-default);
  margin-top: 8px;
  font-weight: 600;
}

.total-amount {
  font-size: 1.25rem;
  color: var(--clr-accent);
  font-weight: 800;
}

.checkout-btn {
  width: 100%;
  padding: 14px;
  border-radius: var(--radius-kmd);
  border: none;
  background: var(--clr-pink);
  color: #fff;
  font-weight: 700;
  font-size: 1rem;
  letter-spacing: .02em;
  transition: all .25s var(--ease-out);
  box-shadow: 0 4px 14px rgba(255, 30, 144, 0.3);
}

.checkout-btn:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(255, 30, 144, 0.45);
  background: #ff339b;
}

.checkout-btn:disabled {
  opacity: .4;
  cursor: not-allowed;
}


.customer-info-modal {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100%;
  width: 100%;
  padding: 24px;
}

.customer-info-box {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-kxl);
  padding: 48px 40px;
  max-width: 480px;
  width: 100%;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
  text-align: center;
  animation: modalSlideIn .4s var(--ease-out);
}

@keyframes modalSlideIn {
  from {
    opacity: 0;
    transform: translateY(-20px) scale(0.95);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.customer-info-title {
  font-size: 2.2rem;
  font-weight: 800;
  color: var(--text-primary);
  margin: 0 0 16px 0;
  letter-spacing: -.02em;
}

.customer-info-subtitle {
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--text-secondary);
  margin: 0 0 8px 0;
}

.customer-info-text {
  font-size: .95rem;
  color: var(--text-muted);
  margin: 0 0 32px 0;
  line-height: 1.5;
}

.customer-info-inputs {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-bottom: 32px;
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
  text-align: left;
}

.input-group label {
  font-size: .85rem;
  font-weight: 600;
  color: var(--text-secondary);
}

.input-group input {
  padding: 14px 16px;
  border-radius: var(--radius-kmd);
  border: 1px solid var(--border-default);
  background: var(--bg-glass);
  color: var(--text-primary);
  font-size: .95rem;
  font-family: inherit;
  transition: all .2s;
}

.input-group input:focus {
  outline: none;
  border-color: var(--clr-primary);
  background: var(--bg-glass-hover);
  box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
}

.customer-info-actions {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.continue-btn {
  padding: 16px 24px;
  border-radius: var(--radius-kmd);
  border: none;
  background: var(--clr-pink);
  color: #fff;
  font-weight: 700;
  font-size: 1rem;
  letter-spacing: .02em;
  transition: all .25s var(--ease-out);
  box-shadow: 0 4px 14px rgba(255, 30, 144, 0.3);
  cursor: pointer;
}

.continue-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(255, 30, 144, 0.5);
  background: #ff339b;
}

.continue-btn:active {
  transform: translateY(0);
}

.skip-link {
  padding: 12px 24px;
  border-radius: var(--radius-kmd);
  border: 1px solid var(--border-default);
  background: transparent;
  color: var(--text-secondary);
  font-weight: 500;
  font-size: .95rem;
  transition: all .2s;
  cursor: pointer;
}

.skip-link:hover {
  background: var(--bg-glass-hover);
  color: var(--text-primary);
  border-color: var(--clr-primary);
}

/* ── Points Display in Header ─────────────────────────────────────── */
.header-points {
  display: inline-block;
  padding: 8px 12px;
  background: linear-gradient(135deg, rgba(255, 193, 7, 0.2), rgba(255, 152, 0, 0.2));
  border-radius: var(--radius-kmd);
  color: var(--text-primary);
  font-weight: 600;
  font-size: 0.95rem;
  border: 1px solid rgba(255, 193, 7, 0.3);
}

/* ── Past Orders Panel (Bottom Left) ───────────────────────────────── */
.past-orders-panel {
  width: 280px;
  max-height: 300px;
  overflow-y: auto;
  border: 1px solid var(--border-default);
  border-radius: var(--radius-klg);
  padding: 16px 12px 16px 16px;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(10px);
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  grid-column: 1;
  grid-row: 2;
  align-self: end;
}

.past-orders-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.past-order-btn {
  padding: 12px 14px;
  border: 1px solid rgba(124, 58, 237, 0.3);
  border-radius: var(--radius-kmd);
  background: rgba(124, 58, 237, 0.05);
  color: var(--text-primary);
  font-weight: 500;
  font-size: 0.9rem;
  cursor: pointer;
  transition: all 0.2s;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.past-order-btn:hover {
  background: rgba(124, 58, 237, 0.1);
  border-color: rgba(124, 58, 237, 0.5);
  transform: translateX(4px);
}

.past-order-btn.active {
  background: rgba(124, 58, 237, 0.2);
  border-color: var(--clr-primary);
  box-shadow: 0 0 12px rgba(124, 58, 237, 0.2);
}

.check-mark {
  font-weight: 700;
  color: var(--clr-primary);
}

/* ── Points Section in Checkout ───────────────────────────────────── */
.points-section {
  margin: 24px 0;
  padding: 20px;
  background: linear-gradient(135deg, rgba(255, 193, 7, 0.1), rgba(255, 152, 0, 0.1));
  border: 1px solid rgba(255, 193, 7, 0.2);
  border-radius: var(--radius-kmd);
}

.points-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.points-header h3 {
  margin: 0;
  font-size: 1rem;
  font-weight: 600;
  color: var(--text-primary);
}

.available-points {
  font-size: 0.9rem;
  color: var(--text-secondary);
  font-weight: 500;
}

.use-points-btn {
  width: 100%;
  padding: 12px 16px;
  border: 1px solid rgba(255, 193, 7, 0.4);
  border-radius: var(--radius-kmd);
  background: rgba(255, 193, 7, 0.15);
  color: var(--text-primary);
  font-weight: 600;
  font-size: 0.95rem;
  cursor: pointer;
  transition: all 0.2s;
}

.use-points-btn:hover {
  background: rgba(255, 193, 7, 0.25);
  border-color: rgba(255, 193, 7, 0.6);
}

.points-input-group {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.points-ratio {
  font-size: 0.85rem;
  color: var(--text-secondary);
  font-weight: 500;
  text-align: center;
  padding: 8px;
  background: rgba(255, 255, 255, 0.05);
  border-radius: var(--radius-ksm);
}

.points-controls {
  display: flex;
  gap: 8px;
}

.points-controls input {
  flex: 1;
  padding: 10px 12px;
  border-radius: var(--radius-kmd);
  border: 1px solid var(--border-default);
  background: var(--bg-glass);
  color: var(--text-primary);
  font-size: 0.9rem;
  font-weight: 500;
}

.points-controls input:focus {
  outline: none;
  border-color: var(--clr-primary);
  box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
}

.points-apply,
.points-cancel {
  padding: 10px 14px;
  border-radius: var(--radius-kmd);
  border: none;
  font-weight: 600;
  font-size: 0.85rem;
  cursor: pointer;
  transition: all 0.2s;
}

.points-apply {
  background: var(--clr-primary);
  color: #fff;
}

.points-apply:hover {
  background: var(--clr-primary-hover);
  transform: translateY(-1px);
}

.points-cancel {
  background: var(--border-default);
  color: var(--text-secondary);
}

.points-cancel:hover {
  background: var(--bg-glass-hover);
  color: var(--text-primary);
}

.clear-points {
  width: 100%;
  padding: 10px 12px;
  border: 1px solid rgba(244, 63, 94, 0.3);
  border-radius: var(--radius-kmd);
  background: rgba(244, 63, 94, 0.05);
  color: var(--text-primary);
  font-weight: 500;
  font-size: 0.85rem;
  cursor: pointer;
  transition: all 0.2s;
}

.clear-points:hover {
  background: rgba(244, 63, 94, 0.15);
  border-color: rgba(244, 63, 94, 0.5);
}

/* ── Discount Row in Checkout Summary ─────────────────────────────── */
.summary-row.discount-row {
  color: var(--clr-primary);
  font-weight: 600;
  background: rgba(124, 58, 237, 0.1);
  padding: 8px 12px;
  border-radius: var(--radius-ksm);
}

/* ── Customer Login Modal ──────────────────────────────────────────── */
.customer-login-modal {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  width: 100%;
  padding: 24px;
  background: linear-gradient(135deg, rgba(124, 58, 237, 0.1), rgba(124, 58, 237, 0.05));
}

.customer-login-box {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-kxl);
  padding: 48px 40px;
  max-width: 420px;
  width: 100%;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
  animation: modalSlideIn .4s var(--ease-out);
}

.login-header {
  text-align: center;
  margin-bottom: 32px;
}

.login-title {
  font-size: 2.2rem;
  font-weight: 800;
  color: var(--text-primary);
  margin: 0 0 8px 0;
  letter-spacing: -.02em;
}

.login-subtitle {
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--text-secondary);
  margin: 0 0 12px 0;
}

.login-text {
  font-size: .95rem;
  color: var(--text-muted);
  margin: 0;
  line-height: 1.5;
}

.login-method-tabs {
  display: flex;
  gap: 12px;
  margin-bottom: 24px;
}

.login-tab {
  flex: 1;
  padding: 12px 16px;
  border: 1px solid var(--border-default);
  border-radius: var(--radius-kmd);
  background: var(--bg-glass);
  color: var(--text-secondary);
  font-weight: 600;
  font-size: .95rem;
  cursor: pointer;
  transition: all .2s;
}

.login-tab:hover {
  background: var(--bg-glass-hover);
  border-color: var(--clr-primary);
  color: var(--text-primary);
}

.login-tab.active {
  background: var(--clr-primary);
  border-color: var(--clr-primary);
  color: #fff;
}

.login-input-group {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-bottom: 20px;
}

.login-input-group input {
  padding: 14px 16px;
  border-radius: var(--radius-kmd);
  border: 1px solid var(--border-default);
  background: var(--bg-glass);
  color: var(--text-primary);
  font-size: .95rem;
  font-family: inherit;
  transition: all .2s;
}

.login-input-group input:focus {
  outline: none;
  border-color: var(--clr-primary);
  background: var(--bg-glass-hover);
  box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
}

.login-input-group input:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.login-error {
  padding: 12px 14px;
  background: rgba(239, 68, 68, 0.12);
  border: 1px solid rgba(239, 68, 68, 0.3);
  border-radius: var(--radius-kmd);
  color: var(--clr-danger);
  font-size: .85rem;
  font-weight: 500;
  margin: 0 0 16px 0;
  text-align: center;
}

.login-btn {
  width: 100%;
  padding: 16px;
  border-radius: var(--radius-kmd);
  border: none;
  background: var(--clr-pink);
  color: #fff;
  font-weight: 800;
  font-size: 1.05rem;
  letter-spacing: .02em;
  transition: all .25s var(--ease-out);
  box-shadow: 0 4px 14px rgba(255, 30, 144, 0.35);
  cursor: pointer;
  margin-bottom: 16px;
}

.login-btn:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(255, 30, 144, 0.5);
  background: #ff339b;
}

.login-btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.login-divider {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 20px 0;
  color: var(--text-muted);
  font-size: .85rem;
  font-weight: 600;
}

.login-divider::before,
.login-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border-default);
}

.skip-btn {
  width: 100%;
  padding: 14px;
  border-radius: var(--radius-kmd);
  border: 1px solid var(--border-default);
  background: transparent;
  color: var(--text-secondary);
  font-weight: 600;
  font-size: .95rem;
  cursor: pointer;
  transition: all .2s;
}

.skip-btn:hover:not(:disabled) {
  background: var(--bg-glass-hover);
  color: var(--text-primary);
  border-color: var(--clr-primary);
}

.skip-btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.login-info {
  margin-top: 20px;
  text-align: center;
  font-size: .8rem;
  color: var(--text-muted);
  line-height: 1.5;
}

/* ── Registration Form ────────────────────────────────────────────────── */
.register-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.form-col {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.form-col label,
.form-group label {
  font-size: .85rem;
  font-weight: 600;
  color: var(--text-secondary);
}

.form-col input,
.form-group input {
  padding: 12px 14px;
  border-radius: var(--radius-kmd);
  border: 1px solid var(--border-default);
  background: var(--bg-glass);
  color: var(--text-primary);
  font-size: .9rem;
  font-family: inherit;
  transition: all .2s;
}

.form-col input:focus,
.form-group input:focus {
  outline: none;
