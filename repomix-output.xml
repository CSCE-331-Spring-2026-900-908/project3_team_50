/* ═══════════════════════════════════════════════════════════════════════
   Boba POS — Custom Design System ("The Boba Spot" Light Theme)
   ═══════════════════════════════════════════════════════════════════════ */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

:root {
  /*#2D1350;  */
  /* ── The Boba Spot Palette ────────────────────────────────────────── */
  --clr-indigo: #4B248B;
  --clr-primary-rgb: 75, 36, 139;
  /* Primary - Headers, Sidebars */
  --clr-pink: #FF1E90;
  /* Secondary - Checkout buttons */
  --clr-pearl: #F8F9FA;
  /* Background - Soft off-white */
  --clr-lavender: #F3E8FF;
  /* Surface - Cards, categories */
  --clr-plum: #2D1350;
  /* Text - High contrast dark */
  --clr-matcha: #88B04B;
  /* Success - Notifications */

  /* ── Semantic Variables ───────────────────────────────────────────── */
  --bg-base: var(--clr-pearl);
  --bg-surface: var(--clr-lavender);
  --bg-surface-raised: #EBDFFF;
  /* Slightly darker lavender for hover/raised */

  --bg-glass: rgba(255, 255, 255, 0.6);
  --bg-glass-hover: rgba(255, 255, 255, 0.9);

  --border-subtle: rgba(75, 36, 139, 0.1);
  --border-default: rgba(75, 36, 139, 0.2);

  --text-primary: var(--clr-plum);
  --text-secondary: #5b4279;
  /* Lighter plum for secondary text */
  --text-muted: #8875a1;
  /* Muted grey-plum */

  --clr-primary: var(--clr-indigo);
  --clr-primary-light: #6c45b5;
  --clr-primary-dark: #341566;

  --clr-accent: var(--clr-pink);
  --clr-accent-light: #ff52ab;

  --clr-success: var(--clr-matcha);
  --clr-success-light: #a6d166;
  --clr-danger: #ef4444;
  --clr-danger-light: #f87171;
  --clr-info: #3b82f6;

  /* ── Spacing & Radius ─────────────────────────────────────────────── */
  --radius-sm: 6px;
  --radius-md: 10px;
  --radius-lg: 16px;
  --radius-xl: 24px;

  --radius-ksm: 3px;
  --radius-kmd: 5px;
  --radius-klg: 8px;
  --radius-kxl: 12px;

  /* ── Shadows ──────────────────────────────────────────────────────── */
  --shadow-sm: 0 1px 3px rgba(45, 19, 80, 0.08);
  --shadow-md: 0 4px 14px rgba(45, 19, 80, 0.12);
  --shadow-lg: 0 10px 30px rgba(45, 19, 80, 0.15);
  --shadow-glow: 0 0 20px rgba(255, 30, 144, 0.3);
  /* Pink glow for accents */

  /* ── Transitions ──────────────────────────────────────────────────── */
  --ease-out: cubic-bezier(.16, 1, .3, 1);
}

/* ── Accessibility: text size (Small / Medium / Large) ─────────────── */
html {
  font-size: 16px;
}

html[data-font-size='small'] {
  font-size: 14px;
}

html[data-font-size='medium'] {
  font-size: 16px;
}

html[data-font-size='large'] {
  font-size: 20px;
}

/* ── Reset / Base ──────────────────────────────────────────────────── */
*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 1rem;
  background: var(--bg-base);
  color: var(--text-primary);
  line-height: 1.6;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

a {
  text-decoration: none;
  color: inherit;
}

button {
  cursor: pointer;
  font-family: inherit;
}

/* ── Typography ────────────────────────────────────────────────────── */
h1 {
  font-size: 2rem;
  font-weight: 800;
  letter-spacing: -.03em;
  color: var(--text-primary);
}

h2 {
  font-size: 1.5rem;
  font-weight: 700;
  letter-spacing: -.02em;
}

h3 {
  font-size: 1.15rem;
  font-weight: 600;
}

/* ── Utilities ─────────────────────────────────────────────────────── */
.glass-card {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  transition: all .25s var(--ease-out);
}

.glass-card:hover {
  background: var(--bg-surface-raised);
  box-shadow: var(--shadow-md);
}

/* ── Custom Scrollbar (Themed) ───────────────────────────────────────── */
::-webkit-scrollbar {
  width: 8px;
}
::-webkit-scrollbar-track {
  background: var(--bg-surface);
  border-radius: 10px;
}
::-webkit-scrollbar-thumb {
  background: var(--clr-primary);
  border-radius: 10px;
}
::-webkit-scrollbar-thumb:hover {
  background: var(--clr-primary-light);
}

/* For Firefox */
* {
  scrollbar-width: thin;
  scrollbar-color: var(--clr-primary) var(--bg-surface);
}
</file>

